# ============================================================
# MOSAMBEE DIGITAL BUSINESS CARDS — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_NAME=Mosambee
NEXT_PUBLIC_COMPANY_WEBSITE=https://mosambee.com

# --- Admin (initial setup) ---
# Set to a strong secret; used to protect the admin seed endpoint
ADMIN_SEED_SECRET=change-me-to-a-strong-random-string
